<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="seq_hospital_patient" model="ir.sequence">
        <field name="name">Hospital Patient</field>
        <field name="code">hospital.patient</field>
        <field name="prefix">PAT/%(year)s/</field>
        <field name="padding">4</field>
        <field name="company_id" eval="False"/>
    </record>

    <record id="seq_hospital_appointment" model="ir.sequence">
        <field name="name">Hospital Appointment</field>
        <field name="code">hospital.appointment</field>
        <field name="prefix">APT/%(year)s/</field>
        <field name="padding">4</field>
        <field name="company_id" eval="False"/>
    </record>
</odoo>
